{
  "name": "solid-web-components-ui",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "publish": "npm run build && npm publish",
    "test": "vitest"
  },
  "dependencies": {
    "solid-js": "^1.8.17"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.56.0",
    "eslint-plugin-solid": "^0.13.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vite-plugin-solid": "^2.10.2",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.2.2",
    "@testing-library/dom": "^9.3.4",
    "jsdom": "^24.0.0"
  },
  "main": "./dist/solid-web-components-ui.umd.js",
  "module": "./dist/solid-web-components-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/solid-web-components-ui.es.js",
      "require": "./dist/solid-web-components-ui.umd.js",
      "types": "./dist/index.d.ts"
    }
  }
}